# Claude Code Voice Harness — harness backend environment
# Copy to .env for local dev, OR (preferred) let the desktop config wizard store
# these in SQLite at ~/.claude-voice-harness/harness.db. Never commit real keys.

# OpenAI API key — used server-side only for Whisper speech-to-text.
OPENAI_API_KEY=

# ElevenLabs API key — used server-side only for text-to-speech.
ELEVENLABS_API_KEY=

# ElevenLabs voice id for spoken responses (chosen in the wizard).
ELEVENLABS_VOICE_ID=

# Port the harness HTTP/WS server binds (default 4620, bind 0.0.0.0).
PORT=4620

# Bearer token required on all non-localhost API requests.
# Normally generated by the wizard and embedded in the pairing QR; set here only
# for headless/curl testing.
PAIRING_TOKEN=
