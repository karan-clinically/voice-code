{
  "name": "claude-voice-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Voice-first control layer for Claude Code sessions on Windows (node-pty/ConPTY)",
  "workspaces": [
    "harness",
    "desktop",
    "mobile-web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node harness/bin/setup.mjs",
    "build:mobile": "npm run build --workspace mobile-web",
    "harness": "npm start --workspace harness",
    "desktop": "npm start --workspace desktop"
  }
}
